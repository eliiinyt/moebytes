---
interface Props {
  id: string;
  title: string;
  author: string;
  category: string;
  date: string;
  commentCount: number;
  preview: string;
  authorPoints: number;
  authorCustomRank: string | null;
}

import { getRankBadge } from "../lib/auth";

const {
  id,
  title,
  author,
  category,
  date,
  commentCount,
  preview,
  authorPoints,
  authorCustomRank,
} = Astro.props;

const categoryMap: Record<string, { class: string; label: string }> = {
  general: { class: "badge-general", label: "General" },
  "off-topic": { class: "badge-off-topic", label: "Off-topic" },
  images: { class: "badge-images", label: "Imágenes (Booru)" },
  errores: { class: "badge-errores", label: "Errores" },
  requests: { class: "badge-requests", label: "Peticiones" },
};

const cat = categoryMap[category] || categoryMap.general;
const initial = author.charAt(0).toUpperCase();

function timeAgo(dateStr: string): string {
  const now = new Date();
  const then = new Date(dateStr);
  const diff = Math.floor((now.getTime() - then.getTime()) / 1000);
  if (diff < 60) return "hace un momento";
  if (diff < 3600) return `hace ${Math.floor(diff / 60)}m`;
  if (diff < 86400) return `hace ${Math.floor(diff / 3600)}h`;
  return `hace ${Math.floor(diff / 86400)}d`;
}
---

<div class="post-card" data-post-id={id}>
  <div class="flex gap-4">
    <div class={`avatar`}>
      {initial}
    </div>
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2 mb-1 flex-wrap">
        <div class="flex items-center gap-1">
          <span class="text-sm font-semibold text-ctp-text">{author}</span>
          <img
            src={getRankBadge(authorPoints, authorCustomRank).icon}
            title={getRankBadge(authorPoints, authorCustomRank).name}
            class="w-3.5 h-3.5 object-contain"
            alt="rank"
          />
        </div>
        <span class={cat.class}>{cat.label}</span>
        <span class="text-xs text-ctp-overlay0">{timeAgo(date)}</span>
      </div>
      <h3 class="text-base font-bold text-ctp-text mb-1 m-0">{title}</h3>
      <p class="text-sm text-ctp-subtext0 leading-relaxed m-0 line-clamp-2">
        {preview}
      </p>
      <div class="flex items-center gap-3 mt-3">
        <span class="text-xs text-ctp-overlay0 flex items-center gap-1">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path
              d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
            ></path>
          </svg>
          {commentCount}
          {commentCount === 1 ? "comentario" : "comentarios"}
        </span>
      </div>
    </div>
  </div>
</div>
