---
import { auth } from "../lib/auth";
import NotificationBell from "./NotificationBell.astro";

interface Props {
  currentPath?: string;
}

const { currentPath = "/" } = Astro.props;

const user = auth.getUserFromRequest(Astro);

const links = [
  { href: "/", label: "Inicio" },
  { href: "/foro", label: "Foro" },
  { href: "/usuarios", label: "Usuarios" },
  { href: "/servicios", label: "Servicios" },
  { href: "/about", label: "Acerca de" },
];

const initial = user ? user.username.charAt(0).toUpperCase() : "";
---

<nav
  class="sticky top-0 z-40 bg-ctp-base/80 backdrop-blur-xl border-b border-ctp-surface0"
>
  <div class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 no-underline group shrink-0">
      <div
        class="w-8 h-8 rounded bg-ctp-mauve/20 flex items-center justify-center text-ctp-mauve font-extrabold text-sm group-hover:bg-ctp-mauve group-hover:text-ctp-base transition-colors duration-200"
      >
        M
      </div>
      <span
        class="text-base font-bold text-ctp-text tracking-tight hidden sm:inline"
        >Moe<span class="text-ctp-mauve">Bytes</span>
      </span>
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-6">
      <div class="flex items-center gap-5">
        {
          links.map((link) => (
            <a
              href={link.href}
              class:list={[
                (currentPath.startsWith(link.href) && link.href !== "/") ||
                (currentPath === "/" && link.href === "/")
                  ? "nav-link-active"
                  : "nav-link",
              ]}
            >
              {link.label}
            </a>
          ))
        }
      </div>

      <div class="w-px h-5 bg-ctp-surface1"></div>

      <!-- Auth section -->
      {
        user ? (
          <a
            href={`/perfiles/${user.username}`}
            class="flex items-center gap-2 no-underline group"
          >
            <div class="w-7 h-7 rounded bg-ctp-surface1 text-ctp-text flex items-center justify-center font-bold text-[10px] overflow-hidden group-hover:ring-1 ring-ctp-mauve transition-all">
              {user.avatar ? (
                <img
                  src={`/avatars/${user.avatar}`}
                  class="w-full h-full object-cover"
                  alt={user.username}
                />
              ) : (
                <span>{initial}</span>
              )}
            </div>
            <span class="text-xs font-semibold text-ctp-text group-hover:text-ctp-mauve transition-colors">
              {user.username}
            </span>
          </a>
        ) : (
          <a
            href="/login"
            class="btn-secondary text-xs px-3 py-1.5 rounded bg-ctp-surface0"
          >
            Iniciar sesión
          </a>
        )
      }

      <!-- Tema lol -->
      <div class="flex items-center gap-1">
        {user && <NotificationBell />}
        <button
          id="theme-toggle"
          class="p-1.5 rounded text-ctp-subtext0 hover:text-ctp-mauve hover:bg-ctp-surface0 transition-colors cursor-pointer"
          aria-label="Cambiar tema"
        >
          <svg
            id="icon-sun"
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="12" cy="12" r="5"></circle>
            <line x1="12" y1="1" x2="12" y2="3"></line>
            <line x1="12" y1="21" x2="12" y2="23"></line>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
            <line x1="1" y1="12" x2="3" y2="12"></line>
            <line x1="21" y1="12" x2="23" y2="12"></line>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
          </svg>
          <svg
            id="icon-moon"
            class="hidden"
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
          </svg>
        </button>
      </div>

      <!-- Mobile Hamburger (no se porque lo hice asi, pero funciona) -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 rounded-lg bg-ctp-surface0 border border-ctp-surface1 text-ctp-subtext0 hover:text-ctp-mauve transition-all duration-200 cursor-pointer"
        aria-label="Abrir menú"
      >
        <svg
          id="icon-menu"
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
        <svg
          id="icon-close"
          class="hidden"
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div
      id="mobile-menu"
      class="hidden md:hidden border-t border-ctp-surface0 bg-ctp-base/95 backdrop-blur-xl"
    >
      <div class="px-6 py-4 flex flex-col gap-3">
        {
          links.map((link) => (
            <a
              href={link.href}
              class:list={[
                currentPath === link.href ? "nav-link-active" : "nav-link",
                "py-2",
              ]}
            >
              {link.label}
            </a>
          ))
        }
        <button
          id="theme-toggle-mobile"
          class="mt-2 p-2.5 rounded-lg bg-ctp-surface0 border border-ctp-surface1 text-ctp-subtext0 text-sm font-medium cursor-pointer text-left"
        >
          🌓 Cambiar tema
        </button>
      </div>
    </div>
  </div>
</nav>

<script is:inline>
  function setupNavbar() {
    const themeToggle = document.getElementById("theme-toggle");
    const themeToggleMobile = document.getElementById("theme-toggle-mobile");
    const iconSun = document.getElementById("icon-sun");
    const iconMoon = document.getElementById("icon-moon");

    if (themeToggle && iconSun && iconMoon) {
      const updateIcons = (isDark) => {
        if (isDark) {
          iconSun.classList.remove("hidden");
          iconMoon.classList.add("hidden");
        } else {
          iconSun.classList.add("hidden");
          iconMoon.classList.remove("hidden");
        }
      };

      updateIcons(document.documentElement.classList.contains("dark"));

      const toggleTheme = () => {
        const isDark = document.documentElement.classList.toggle("dark");
        localStorage.setItem("theme", isDark ? "dark" : "light");
        updateIcons(isDark);
      };

      themeToggle.addEventListener("click", toggleTheme);
      if (themeToggleMobile)
        themeToggleMobile.addEventListener("click", toggleTheme);
    }

    // Mobile menu
    const menuBtn = document.getElementById("mobile-menu-btn");
    const mobileMenu = document.getElementById("mobile-menu");
    const iconMenu = document.getElementById("icon-menu");
    const iconClose = document.getElementById("icon-close");

    if (menuBtn && mobileMenu && iconMenu && iconClose) {
      menuBtn.addEventListener("click", () => {
        mobileMenu.classList.toggle("hidden");
        iconMenu.classList.toggle("hidden");
        iconClose.classList.toggle("hidden");
      });
    }
  }

  // corre al cargar la pagina y despues de cada transicion
  document.addEventListener("astro:page-load", setupNavbar);
</script>
