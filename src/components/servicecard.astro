---
interface Props {
  title: string;
  description: string;
  icon?: string;
  href?: string;
  status?: "online" | "offline" | "degraded";
}

const { title, description, icon, href, status } = Astro.props;
const Tag = href ? "a" : "div";
---

<Tag
  class:list={[href ? "card-clickable service-link" : "card", "relative"]}
  href={href}
  target={href?.startsWith("http") ? "_blank" : undefined}
  rel={href?.startsWith("http") ? "noopener noreferrer" : undefined}
>
  {
    status && (
      <div class="absolute top-4 right-4 flex items-center gap-1.5 text-xs font-semibold bg-ctp-surface1 px-2 py-1 rounded-full z-2">
        <span class={`dot-${status}`} />
        <span class="text-ctp-subtext0">
          {status.charAt(0).toUpperCase() + status.slice(1)}
        </span>
      </div>
    )
  }

  {
    icon && (
      <div class="w-12 h-12 rounded-lg flex items-center justify-center bg-ctp-mauve/15 text-ctp-mauve mb-4">
        <Fragment set:html={icon} />
      </div>
    )
  }

  <h3 class="text-base font-bold text-ctp-text mb-1">{title}</h3>
  <p class="text-sm text-ctp-subtext0 leading-relaxed m-0">{description}</p>

  {
    href && (
      <span class="open-hint mt-4 inline-flex items-center gap-1 text-xs font-semibold text-ctp-mauve">
        Abrir →
      </span>
    )
  }
</Tag>

<style>
  .open-hint {
    opacity: 0;
    transition: opacity 200ms ease;
  }
  .service-link:hover .open-hint {
    opacity: 1;
  }
</style>
