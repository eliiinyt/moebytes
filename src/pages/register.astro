---
import Layout from "../layouts/Layout.astro";
import { auth } from "../lib/auth";

if (auth.getUserFromRequest(Astro)) {
  return Astro.redirect("/foro");
}
---

<Layout title="MoeBytes | Registro" currentPath="/register">
  <div class="max-w-md mx-auto mt-12">
    <div
      class="bg-ctp-surface0 border border-ctp-surface1 rounded-lg p-8 shadow-sm"
    >
      <h1 class="text-xl font-bold text-ctp-text text-center mb-6">
        Unirse a MoeBytes
      </h1>

      <form id="register-form" class="flex flex-col gap-4">
        <div
          id="error-alert"
          class="hidden bg-ctp-red/15 text-ctp-red text-sm px-4 py-3 rounded-lg border border-ctp-red/30 mb-2"
        >
        </div>

        <div>
          <label class="block text-sm font-medium text-ctp-subtext0 mb-1.5"
            >Usuario</label
          >
          <input
            type="text"
            id="username"
            class="input py-2"
            required
            minlength="3"
            maxlength="30"
            pattern="[a-zA-Z0-9_\-]+"
            title="Solo letras, números, guiones y guiones bajos"
          />
          <p class="text-[10px] text-ctp-overlay0 mt-1 mb-0">
            Sin espacios. Mínimo 3 caracteres.
          </p>
        </div>

        <div class="mb-2">
          <label class="block text-sm font-medium text-ctp-subtext0 mb-1.5"
            >Correo Electrónico</label
          >
          <input type="email" id="email" class="input py-2" required />
        </div>

        <div class="mb-2">
          <label class="block text-sm font-medium text-ctp-subtext0 mb-1.5"
            >Contraseña</label
          >
          <input
            type="password"
            id="password"
            class="input py-2 mb-4"
            required
            minlength="6"
          />

          <label class="block text-sm font-medium text-ctp-subtext0 mb-1.5"
            >Confirmar Contraseña</label
          >
          <input
            type="password"
            id="confirm-password"
            class="input py-2"
            required
            minlength="6"
          />
        </div>

        <button type="submit" class="btn-primary justify-center w-full"
          >Crear cuenta</button
        >
      </form>

      <div
        class="mt-6 text-center text-sm text-ctp-subtext0 border-t border-ctp-surface1 pt-4"
      >
        ¿Ya tienes cuenta? <a
          href="/login"
          class="text-ctp-mauve hover:text-ctp-pink transition-colors"
          >Inicia sesión</a
        >
      </div>
    </div>
  </div>

  <script is:inline>
    (() => {
      const form = document.getElementById("register-form");
      const errorAlert = document.getElementById("error-alert");

      if (!form) return;

      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        errorAlert.classList.add("hidden");

        const username = document.getElementById("username").value;
        const email = document.getElementById("email").value;
        const password = document.getElementById("password").value;
        const confirmPassword =
          document.getElementById("confirm-password").value;

        if (password !== confirmPassword) {
          errorAlert.textContent = "Las contraseñas no coinciden.";
          errorAlert.classList.remove("hidden");
          return;
        }

        try {
          const res = await fetch("/api/auth/register", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              username,
              email,
              password,
              confirmPassword,
            }),
          });

          if (!res.ok) {
            const data = await res.json();
            throw new Error(data.error || "Error al registrarse");
          }

          window.location.href = "/foro";
        } catch (err) {
          errorAlert.textContent = err.message;
          errorAlert.classList.remove("hidden");
        }
      });
    })();
  </script>
</Layout>
