---
import Layout from "../layouts/Layout.astro";
import ServiceCard from "../components/servicecard.astro";

const iconMusic =
  '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>';

const iconCrosshair =
  '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="22" y1="12" x2="18" y2="12"/><line x1="6" y1="12" x2="2" y2="12"/><line x1="12" y1="6" x2="12" y2="2"/><line x1="12" y1="22" x2="12" y2="18"/></svg>';

const iconServer =
  '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>';

const iconStar =
  '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.27 5.82 22 7 14.14l-5-4.87 6.91-1.01z"/></svg>';
---
 <!-- esto es tremenda bullshit, los herocard debo cambiarlos luego -->
<Layout title="MoeBytes | Servicios" currentPath="/servicios">
  <section>
    <h1 class="text-2xl font-bold text-ctp-text mb-2">Servicios</h1>
    <p class="text-sm text-ctp-subtext0 mb-8">
      Todos nuestros servicios self-hosted, disponibles 24/7.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      <ServiceCard
        title="Navidrome"
        description="Streaming de música self-hosted."
        icon={iconMusic}
        href="https://music.moebytes.org"
        status="online"
      />
      <ServiceCard
        title="CS:GO"
        description="Servidor privado de juegos."
        icon={iconCrosshair}
        href="https://csgo.moebytes.org"
        status="online"
      />
      <ServiceCard
        title="MCSManager"
        description="Panel de gestión de servidores."
        icon={iconServer}
        href="https://panel.moebytes.org"
        status="online"
      />
      <ServiceCard
        title="Gachapon"
        description="Sistema de gacha y coleccionables."
        icon={iconStar}
        href="https://dashboard.moebytes.org/gachapon"
        status="online"
      />
    </div>
  </section>
</Layout>
