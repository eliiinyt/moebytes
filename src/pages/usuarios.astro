---
import Layout from "../layouts/Layout.astro";
import { auth } from "../lib/auth";
// jaja imagina usar getUserFromRequest
const user = auth.getUserFromRequest(Astro);
---

<Layout title="Buscar Usuarios | MoeBytes" currentPath="/usuarios">
  <div class="max-w-2xl mx-auto">
    <div class="mb-8">
      <h1 class="text-2xl font-bold text-ctp-text mb-2">Comunidad</h1>
      <p class="text-sm text-ctp-subtext0">Busca a otros usuarios de MoeBytes para seguirlos o hacer nuevas amistades.</p>
    </div>

    <div class="bg-ctp-surface0 p-1 rounded-xl border border-ctp-surface1 mb-8 shadow-sm">
      <div class="relative">
        <div class="absolute inset-y-0 left-4 flex items-center pointer-events-none text-ctp-overlay0">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        </div>
        <input 
          type="text" 
          id="user-search-input" 
          placeholder="Buscar por nombre de usuario..." 
          class="w-full bg-transparent border-none py-4 pl-12 pr-4 text-ctp-text focus:ring-0 placeholder-ctp-overlay0"
          autocomplete="off"
        />
      </div>
    </div>

    <div id="search-results" class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="col-span-full py-12 text-center text-ctp-overlay0 italic">
        Escribe al menos 2 caracteres para comenzar a buscar...
      </div>
    </div>
  </div>

  <template id="user-card-template">
    <a href="" class="flex items-center gap-4 p-4 rounded-xl border border-ctp-surface1 bg-ctp-mantle hover:bg-ctp-surface0/50 transition-all no-underline group shadow-sm hover:shadow-md">
      <div class="w-12 h-12 rounded-full overflow-hidden border border-ctp-surface2 bg-ctp-crust flex items-center justify-center font-bold text-lg text-ctp-mauve">
        <img src="" class="avatar-img w-full h-full object-cover hidden" />
        <span class="avatar-initial"></span>
      </div>
      <div class="min-w-0">
        <div class="flex items-center gap-1.5 mb-0.5">
          <span class="user-name font-bold text-ctp-text group-hover:text-ctp-mauve transition-colors truncate"></span>
          <span class="user-label text-[9px] px-1.5 py-0.5 rounded bg-ctp-surface1 text-ctp-overlay0 uppercase font-bold border border-ctp-surface2"></span>
        </div>
        <div class="text-[10px] text-ctp-overlay0 uppercase tracking-wider font-bold points-text"></div>
      </div>
    </a>
  </template>

  <script is:inline>
    document.addEventListener("astro:page-load", () => {
      const searchInput = document.getElementById('user-search-input');
      const resultsContainer = document.getElementById('search-results');
      const template = document.getElementById('user-card-template');

      if (!searchInput || !resultsContainer || !template) return;

      let debounceTimer;

      searchInput.addEventListener('input', () => {
        clearTimeout(debounceTimer);
        const query = searchInput.value.trim();

        if (query.length < 2) {
          resultsContainer.innerHTML = `
            <div class="col-span-full py-12 text-center text-ctp-overlay0 italic">
              Escribe al menos 2 caracteres para comenzar a buscar...
            </div>
          `;
          return;
        }

        debounceTimer = setTimeout(async () => {
          try {
            const res = await fetch(`/api/users/search?q=${encodeURIComponent(query)}`);
            const users = await res.json();

            if (users.length === 0) {
              resultsContainer.innerHTML = `
                <div class="col-span-full py-12 text-center text-ctp-overlay0 italic">
                  No se encontraron usuarios con ese nombre.
                </div>
              `;
              return;
            }

            resultsContainer.innerHTML = '';
            users.forEach(user => {
              const clone = template.content.cloneNode(true);
              const anchor = clone.querySelector('a');
              anchor.href = `/perfiles/${user.username}`;
              
              const img = clone.querySelector('.avatar-img');
              const initial = clone.querySelector('.avatar-initial');
              if (user.avatar) {
                img.src = `/avatars/${user.avatar}`;
                img.classList.remove('hidden');
                initial.classList.add('hidden');
              } else {
                initial.textContent = user.username.charAt(0).toUpperCase();
              }

              clone.querySelector('.user-name').textContent = user.username;
              clone.querySelector('.user-label').textContent = user.username === 'eliiin' ? 'Creador' : 'Usuario';
              clone.querySelector('.points-text').textContent = `${user.points} Puntos`;

              resultsContainer.appendChild(clone);
            });
          } catch (err) {
            console.error(err);
          }
        }, 300);
      });
    });
  </script>
</Layout>
