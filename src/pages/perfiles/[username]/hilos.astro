---
import Layout from "../../../layouts/Layout.astro";
import { db } from "../../../lib/database";
import { auth, getRankBadge } from "../../../lib/auth";

const { username } = Astro.params;
const currentUser = auth.getUserFromRequest(Astro);

// Fetch user again hola
const profileUser = db.query("SELECT id, username FROM users WHERE username = ?").get(username) as any;

if (!profileUser) {
  return Astro.redirect("/404");
}

// esto hace fetch a todos los hilos del usuario
const posts = db.query(`
  SELECT p.*, 
    (SELECT COUNT(*) FROM comments c WHERE c.post_id = p.id) as comment_count,
    u.username as author, 
    u.avatar as author_avatar,
    u.points as author_points,
    u.custom_rank as author_custom_rank
  FROM posts p
  JOIN users u ON p.user_id = u.id
  WHERE p.user_id = ?
  ORDER BY p.created_at DESC
`).all(profileUser.id) as any[];

function timeAgo(dateStr: string) {
  const diff = Math.floor((Date.now() - new Date(dateStr).getTime()) / 1000);
  if (diff < 60) return "hace un momento";
  if (diff < 3600) return `hace ${Math.floor(diff / 60)}m`;
  if (diff < 86400) return `hace ${Math.floor(diff / 3600)}h`;
  return `hace ${Math.floor(diff / 86400)}d`;
}

function getInitial(name: string) {
  return (name || "A").charAt(0).toUpperCase();
}
---

<Layout title={`Hilos de ${profileUser.username} | MoeBytes`} currentPath="/perfiles">
  <div class="mb-6 flex justify-between items-center">
    <a href={`/perfiles/${profileUser.username}`} class="btn-sm text-[11px] no-underline flex items-center gap-2">
      ← Volver al Perfil
    </a>
  </div>

  <div class="forum-table-header rounded-t-lg">
    <h1 class="text-base m-0 flex items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
      Todos los hilos de {profileUser.username}
    </h1>
  </div>

  <div class="border border-t-0 border-ctp-surface1 rounded-b-lg overflow-hidden bg-ctp-base mb-8">
    {posts.length === 0 ? (
      <div class="px-4 py-12 text-center text-ctp-overlay0 flex flex-col items-center justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mb-4 opacity-50"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
        <p class="m-0 text-sm">Este usuario no ha iniciado ningún hilo.</p>
      </div>
    ) : (
      posts.map(post => (
        <a href={`/foro/${post.id}`} class="forum-row flex items-center gap-4 p-4 border-b border-ctp-surface1 last:border-b-0 group">
          <div class="w-10 h-10 rounded bg-ctp-surface0 flex flex-col items-center justify-center border border-ctp-surface1 shrink-0 group-hover:border-ctp-mauve/50 transition-colors">
            <span class="text-xs font-bold text-ctp-text">{post.comment_count || 0}</span>
            <span class="text-[9px] text-ctp-overlay0 uppercase tracking-tighter mix-blend-luminosity">Resp</span>
          </div>
          
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 flex-wrap mb-1">
              <span class="text-base font-semibold text-ctp-text truncate group-hover:text-ctp-mauve transition-colors">{post.title}</span>
              <span class={`badge-${post.category} shrink-0`}>{post.category}</span>
            </div>
            
            <div class="flex items-center gap-2 text-xs text-ctp-overlay0">
              <div class="flex items-center gap-1">
                <span class="truncate">{post.author}</span>
                <img src={getRankBadge(post.author_points, post.author_custom_rank).icon} title={getRankBadge(post.author_points, post.author_custom_rank).name} class="w-2.5 h-2.5 object-contain" alt="rank" />
              </div>
              <span>•</span>
              <span>{timeAgo(post.created_at)}</span>
            </div>
          </div>
        </a>
      ))
    )}
  </div>
</Layout>
