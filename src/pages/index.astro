---
import Layout from "../layouts/Layout.astro";
import { db } from "../lib/database";
import { getRankBadge } from "../lib/auth";

const recentPosts = db
  .query(
    `
  SELECT
    p.id, p.title, p.category, p.created_at,
    u.username as author, u.avatar as author_avatar, u.points as author_points, u.custom_rank as author_custom_rank,
    (SELECT COUNT(*) FROM comments c WHERE c.post_id = p.id) as comment_count,
    (SELECT COUNT(*) FROM post_likes pl WHERE pl.post_id = p.id) as like_count
  FROM posts p
  JOIN users u ON p.user_id = u.id
  ORDER BY p.created_at DESC
  LIMIT 4
`,
  )
  .all() as any[];

function timeAgo(dateStr: string) {
  const diff = Math.floor((Date.now() - new Date(dateStr).getTime()) / 1000);
  if (diff < 60) return "hace un momento";
  if (diff < 3600) return `hace ${Math.floor(diff / 60)}m`;
  if (diff < 86400) return `hace ${Math.floor(diff / 3600)}h`;
  return `hace ${Math.floor(diff / 86400)}d`;
}

function getInitial(name: string) {
  return (name || "A").charAt(0).toUpperCase();
}
---

<Layout title="MoeBytes | Inicio" currentPath="/">
  <!-- banner !!-->
  <div class="bg-ctp-surface0 border border-ctp-surface1 rounded-lg p-6 mb-6">
    <div
      class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4"
    >
      <div>
        <h1 class="text-xl font-bold text-ctp-text m-0">
          Bienvenido a <span class="text-ctp-mauve">MoeBytes</span>
        </h1>
        <p class="text-sm text-ctp-subtext0 mt-1" style="margin-bottom:0">
          Comunidad de gaming, tecnología y proyectos. Discute, comparte y
          conecta.
        </p>
      </div>
      <div class="flex gap-2 shrink-0">
        <a href="/foro" class="btn-primary text-xs px-4 py-2">Ir al Foro</a>
        <a href="/servicios" class="btn-secondary text-xs px-4 py-2"
          >Servicios</a
        >
      </div>
    </div>
  </div>

  <!-- categorías del foro -->
  <div class="mb-6">
    <div class="forum-table-header">
      <span>Categorías del Foro</span>
    </div>
    <div
      class="border border-t-0 border-ctp-surface1 rounded-b-lg overflow-hidden"
    >
      <!-- GENERAL -->
      <a href="/foro?category=general" class="forum-row group">
        <div class="flex items-center gap-3">
          <div
            class="w-9 h-9 rounded bg-ctp-blue/15 text-ctp-blue flex items-center justify-center shrink-0"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
              ></path>
            </svg>
          </div>
          <div>
            <span
              class="text-sm font-semibold text-ctp-text group-hover:text-ctp-mauve transition-colors"
              >General</span
            >
            <p class="text-xs text-ctp-overlay0 m-0">
              Discusiones generales, presentaciones y anuncios del proyecto.
            </p>
          </div>
        </div>
      </a>
      <!-- OFF-TOPIC -->
      <a href="/foro?category=off-topic" class="forum-row group">
        <div class="flex items-center gap-3">
          <div
            class="w-9 h-9 rounded bg-ctp-peach/15 text-ctp-peach flex items-center justify-center shrink-0"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><circle cx="12" cy="12" r="10"></circle><path
                d="M8 14s1.5 2 4 2 4-2 4-2"></path><line
                x1="9"
                y1="9"
                x2="9.01"
                y2="9"></line><line x1="15" y1="9" x2="15.01" y2="9"></line>
            </svg>
          </div>
          <div>
            <span
              class="text-sm font-semibold text-ctp-text group-hover:text-ctp-mauve transition-colors"
              >Off-Topic</span
            >
            <p class="text-xs text-ctp-overlay0 m-0">
              Anime, videojuegos, memes y temas misceláneos.
            </p>
          </div>
        </div>
      </a>
      <!-- IMAGENES -->
      <a href="/foro?category=images" class="forum-row group">
        <div class="flex items-center gap-3">
          <div
            class="w-9 h-9 rounded bg-ctp-green/15 text-ctp-green flex items-center justify-center shrink-0"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              class="opacity-80"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><rect x="3" y="3" width="18" height="18" rx="2" ry="2"
              ></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline
                points="21 15 16 10 5 21"></polyline>
            </svg>
          </div>
          <div>
            <span
              class="text-sm font-semibold text-ctp-text group-hover:text-ctp-mauve transition-colors"
              >Imágenes (Booru)</span
            >
            <p class="text-xs text-ctp-overlay0 m-0">
              Galería comunitaria. Wallpapers, fan-arts y media.
            </p>
          </div>
        </div>
      </a>
      <!-- ERRORES -->
      <a href="/foro?category=errores" class="forum-row group">
        <div class="flex items-center gap-3">
          <div
            class="w-9 h-9 rounded bg-ctp-red/15 text-ctp-red flex items-center justify-center shrink-0"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"
              ></path><line x1="12" y1="9" x2="12" y2="13"></line><line
                x1="12"
                y1="17"
                x2="12.01"
                y2="17"></line>
            </svg>
          </div>
          <div>
            <span
              class="text-sm font-semibold text-ctp-text group-hover:text-ctp-mauve transition-colors"
              >Errores</span
            >
            <p class="text-xs text-ctp-overlay0 m-0">
              Reporte de bugs, problemas técnicos del foro y feedback.
            </p>
          </div>
        </div>
      </a>
      <!-- PETICIONES -->
      <a href="/foro?category=requests" class="forum-row group border-b-0">
        <div class="flex items-center gap-3">
          <div
            class="w-9 h-9 rounded bg-ctp-yellow/15 text-ctp-yellow flex items-center justify-center shrink-0"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><circle cx="12" cy="12" r="10"></circle><path
                d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path><line
                x1="12"
                y1="17"
                x2="12.01"
                y2="17"></line>
            </svg>
          </div>
          <div>
            <span
              class="text-sm font-semibold text-ctp-text group-hover:text-ctp-mauve transition-colors"
              >Peticiones</span
            >
            <p class="text-xs text-ctp-overlay0 m-0">
              Ideas, futuras características o requests misceláneos.
            </p>
          </div>
        </div>
      </a>
    </div>
  </div>

  <!-- últimos hilos -->
  <div class="mb-6">
    <div class="forum-table-header">
      <span>Últimos Hilos</span>
      <a
        href="/foro"
        class="text-xs font-normal text-ctp-subtext0 hover:text-ctp-mauve transition-colors no-underline"
        >Ver todos →</a
      >
    </div>
    <div
      id="recent-posts-list"
      class="border border-t-0 border-ctp-surface1 rounded-b-lg overflow-hidden"
    >
      <!-- esto es el ssr, renderiza los post recientes....  -->
      {
        recentPosts.length === 0 ? (
          <div class="px-4 py-6 text-center text-sm text-ctp-overlay0">
            No hay hilos recientes.
          </div>
        ) : (
          recentPosts.map((post) => (
            <a
              href={`/foro/${post.id}`}
              class="forum-row flex items-center justify-between gap-3"
            >
              <div class="flex items-center gap-3 min-w-0">
                <div class="avatar shrink-0">
                  {post.author_avatar ? (
                    <img
                      src={`/avatars/${post.author_avatar}`}
                      class="w-full h-full object-cover rounded"
                      alt={post.author}
                    />
                  ) : (
                    <span>{getInitial(post.author)}</span>
                  )}
                </div>
                <div class="min-w-0">
                  <div class="flex items-center gap-2 flex-wrap mb-0.5">
                    <span class="text-sm font-semibold text-ctp-text truncate block">
                      {post.title}
                    </span>
                    <span class={`badge-${post.category} shrink-0`}>
                      {post.category}
                    </span>
                  </div>
                  <div class="flex items-center gap-2">
                    <div class="flex items-center gap-1">
                      <span class="text-xs text-ctp-overlay0">
                        {post.author}
                      </span>
                      <img
                        src={
                          getRankBadge(
                            post.author_points,
                            post.author_custom_rank,
                          ).icon
                        }
                        title={
                          getRankBadge(
                            post.author_points,
                            post.author_custom_rank,
                          ).name
                        }
                        class="w-2.5 h-2.5 object-contain"
                        alt="rank"
                      />
                    </div>
                    <span class="text-xs text-ctp-surface2">·</span>
                    <span class="text-xs text-ctp-overlay0">
                      {timeAgo(post.created_at)}
                    </span>
                  </div>
                </div>
              </div>
              <div class="flex items-center gap-1.5 text-xs text-ctp-overlay0 shrink-0">
                <img src="/likes/cutucar_prendido.png" class="w-4 h-4 object-contain opacity-70" alt="Likes" />
                {post.like_count}
              </div>
            </a>
          ))
        )
      }
    </div>
  </div>
</Layout>
